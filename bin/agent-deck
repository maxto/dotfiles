#!/usr/bin/env bash
# agent-deck — launch the 3-pane "deck" layout and manage its herdr sessions.
#
# Layout (all panes anchored to the launch dir):
#   left 60% = agent (plain shell) | right 40%: top 40% = bash, bottom 60% = files (br)
#
# Usage:
#   agent-deck [name]            Launch the deck in a new session.
#   agent-deck session list      Show herdr sessions and the workspaces they hold.
#   agent-deck session open <name>      Attach this terminal to an existing session.
#   agent-deck session kill <name>...   Stop and remove one or more sessions.
#
# Launch behavior is context-aware:
#   - Outside herdr: attaches to a persistent herdr session named after the
#     folder (or the given name). If a session with that name already exists it
#     REATTACHES to it; otherwise it creates the session, builds the deck, and
#     attaches. So `agent-deck teamA` always returns you to teamA. The session
#     survives closing the terminal — reopen it with the same command or
#     `agent-deck session open <name>`, or stop it with `agent-deck session kill`.
#     Use distinct names (or folders) for independent sessions.
#   - Inside herdr (HERDR_ENV=1): turns the CURRENT empty tab into the deck
#     (the pane you run it in becomes "agent"), within the current session.
set -euo pipefail

command -v jq     >/dev/null || { echo "agent-deck: jq is required"     >&2; exit 1; }
command -v herdr  >/dev/null || { echo "agent-deck: herdr is required"  >&2; exit 1; }
command -v setsid >/dev/null || { echo "agent-deck: setsid is required" >&2; exit 1; }

# build_deck <anchor_pane> <dir>: split the anchor into the agent|bash/files
# layout, launch broot in the files pane, and label the three panes.
build_deck() {
  local anchor="$1" dir="$2" right bottom

  # Right split: agent keeps 60%, new right pane = 40% (bash).
  right="$(herdr pane split "$anchor" --direction right --ratio 0.60 --cwd "$dir" --no-focus | jq -r '.result.pane.pane_id')"

  # Down split of the right pane: bash keeps 40%, new bottom = 60% (files).
  bottom="$(herdr pane split "$right" --direction down --ratio 0.40 --cwd "$dir" --no-focus | jq -r '.result.pane.pane_id')"

  # Launch broot (via the `br` launcher) in the bottom-right pane, rooted at $dir.
  herdr pane run "$bottom" "br \"$dir\"" >/dev/null

  # Label the panes.
  herdr pane rename "$anchor" agent >/dev/null
  herdr pane rename "$right"  bash  >/dev/null
  herdr pane rename "$bottom" files >/dev/null
}

# session_socket <name>: print the socket path of a running session, else nothing.
session_socket() {
  herdr session list --json \
    | jq -r --arg n "$1" '.sessions[] | select(.name == $n and .running == true) | .socket_path'
}

# cmd_session_list: table of every session and the workspaces it currently holds.
cmd_session_list() {
  printf '%-24s %-8s %s\n' SESSION RUNNING WORKSPACES
  herdr session list --json \
    | jq -r '.sessions[] | [.name, (.running | tostring), .socket_path] | @tsv' \
    | while IFS=$'\t' read -r name running sock; do
        ws=""
        if [[ "$running" == "true" && -S "$sock" ]]; then
          ws="$(HERDR_SOCKET_PATH="$sock" herdr workspace list 2>/dev/null \
                | jq -r '[.result.workspaces[].label] | join(", ")')"
        fi
        printf '%-24s %-8s %s\n' "$name" "$running" "$ws"
      done
}

# cmd_session_open <name>: attach this terminal to an existing session. Refuses
# an unknown name so a typo doesn't silently spawn a new empty session.
cmd_session_open() {
  local name="${1:-}"
  [[ -n "$name" ]] || { echo "agent-deck: 'session open' richiede un nome" >&2; exit 1; }
  [[ "${HERDR_ENV:-}" != "1" ]] || { echo "agent-deck: sei già dentro herdr; lancia 'session open' da una shell normale" >&2; exit 1; }
  local exists
  exists="$(herdr session list --json | jq -r --arg n "$name" '.sessions[] | select(.name == $n) | .name')"
  [[ -n "$exists" ]] || { echo "agent-deck: nessuna sessione '$name' (vedi: agent-deck session list)" >&2; exit 1; }
  exec herdr --session "$name"
}

# cmd_session_kill <name>...: stop and remove the given sessions entirely, so
# they no longer linger in `session list` as stopped. herdr's built-in "default"
# session cannot be deleted, so we refuse it up front. Note herdr exits 0 even on
# failure and reports the error as JSON on stdout, so we parse that ourselves.
cmd_session_kill() {
  [[ $# -gt 0 ]] || { echo "agent-deck: 'session kill' richiede almeno un nome" >&2; exit 1; }
  local rc=0
  for name in "$@"; do
    if [[ "$name" == "default" ]]; then
      echo "agent-deck: la sessione 'default' è interna a herdr e non può essere rimossa" >&2
      rc=1
      continue
    fi
    herdr session stop "$name" >/dev/null 2>&1 || true
    local out err
    out="$(herdr session delete "$name" 2>&1)"
    err="$(echo "$out" | jq -r 'if type == "object" and has("error") then .error.message else empty end' 2>/dev/null || true)"
    if [[ -n "$err" ]]; then
      echo "agent-deck: impossibile rimuovere '$name': $err" >&2
      rc=1
    fi
  done
  return "$rc"
}

# --- Subcommand dispatch -----------------------------------------------------
if [[ "${1:-}" == "session" ]]; then
  case "${2:-}" in
    list) cmd_session_list ;;
    open) cmd_session_open "${3:-}" ;;
    kill) shift 2; cmd_session_kill "$@" ;;
    *)    echo "usage: agent-deck session {list | open <name> | kill <name>...}" >&2; exit 1 ;;
  esac
  exit 0
fi

dir="$PWD"
label="${1:-$(basename "$dir")}"

# --- Inside herdr: build the deck in the current tab -------------------------
if [[ "${HERDR_ENV:-}" == "1" ]]; then
  # Guard: only build in place when the current tab is a single empty pane.
  panes="$(herdr pane list | jq --arg t "$HERDR_TAB_ID" '[.result.panes[] | select(.tab_id == $t)] | length')"
  if [[ "$panes" != "1" ]]; then
    echo "agent-deck: questo tab ha già più pane; apri un tab nuovo (herdr tab create) e rilancia" >&2
    exit 1
  fi

  build_deck "$HERDR_PANE_ID" "$dir"
  herdr tab rename "$HERDR_TAB_ID" "$label" >/dev/null

  echo "agent-deck: layout ready (agent | bash / files) in $label"
  exit 0
fi

# --- Outside herdr: attach to (or create) a persistent named session ---------
# The name is just the label. If a session with that name already exists we
# reattach to it instead of duplicating — so re-running returns you to it.
session="$label"

if herdr session list --json | jq -e --arg n "$session" '.sessions[] | select(.name == $n)' >/dev/null; then
  echo "agent-deck: reattaching to existing session '$session'"
  exec herdr --session "$session"
fi

# New session: start its server in its OWN session (setsid), so it becomes a
# detached daemon that survives this terminal closing. Without setsid the
# server inherits the terminal's session and dies on hangup with the client.
setsid herdr --session "$session" server >/dev/null 2>&1 &
sock=""
for _ in $(seq 1 50); do
  sock="$(session_socket "$session")"
  [[ -n "$sock" ]] && break
  sleep 0.1
done
[[ -n "$sock" ]] || { echo "agent-deck: session '$session' did not start" >&2; exit 1; }
export HERDR_SOCKET_PATH="$sock"

# Create the deck's workspace inside that session, then build the layout.
create="$(herdr workspace create --cwd "$dir" --label "$label" --no-focus)"
anchor="$(echo "$create" | jq -r '.result.root_pane.pane_id')"
wsid="$(echo "$create" | jq -r '.result.workspace.workspace_id')"

build_deck "$anchor" "$dir"
herdr workspace focus "$wsid" >/dev/null 2>&1 || true

echo "agent-deck: session '$session' ready (agent | bash / files)"

# Attach this terminal to its own session.
exec herdr --session "$session"
